rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. RULES FOR THE "schedules" COLLECTION
    match /schedules/{scheduleId} {
      
      // Validate the data structure and enforce owner ID matching
      function isValidSchedule(data) {
        return data.userId is string &&
               data.userId == request.auth.uid &&
               data.title is string &&
               data.title.size() <= 200;
      }

      // Allow reads only if the user is the owner of the schedule
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      
      // Secure list query: Ensure the client must filter queries by owner ID
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Allow creation of a new schedule with a server-validated timestamp
      allow create: if isSignedIn() && 
                    isValidId(scheduleId) && 
                    isValidSchedule(request.resource.data) && 
                    request.resource.data.createdAt == request.time;

      // Allow updates with action-based safety gates
      allow update: if isSignedIn() && 
                    isOwner(resource.data.userId) && 
                    isValidSchedule(request.resource.data) && 
                    request.resource.data.updatedAt == request.time && 
                    request.resource.data.createdAt == resource.data.createdAt; // Prevent editing createdAt

      // Allow deletion only by the owner
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }
  }
}
